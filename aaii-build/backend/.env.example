# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: switch to a cheaper/faster model for summaries & labels
# SUMMARY_MODEL=claude-haiku-4-5
# LABEL_MODEL=claude-haiku-4-5

# Optional: embedding model (any sentence-transformers model)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: clustering / fetch tuning
# MAX_CLUSTERS=8
# MAX_RESULTS_PER_SOURCE=25

# Optional: higher Semantic Scholar rate limits
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: comma-separated CORS origins for the frontend
# ALLOWED_ORIGINS=http://localhost:5173
